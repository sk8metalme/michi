# MCP Credentials (local only - use template for sharing)
~/.cursor/mcp.json

# IDE-specific configurations (generated by cc-sdd)
# Users should run `npx cc-sdd@latest --lang ja --cursor` or `--claude` to generate these
.claude/
.cursor/

# Project-specific AI-DLC settings (generated by cc-sdd or setup scripts)
# Users should run setup-existing.sh or cc-sdd to generate these
# Includes: specs/, config.json, settings/, steering/, project.json, etc.
.kiro/

# Michi-specific project settings (user/machine-specific configuration)
# Contains config.json with user credentials, project-specific settings
.michi/

# AI Context
AGENTS.mdecho
